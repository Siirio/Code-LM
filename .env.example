# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which AI to use: "anthropic" | "deepseek"
LLM_PROVIDER=anthropic

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── DeepSeek ──────────────────────────────────────────────────────────────────
# Set LLM_PROVIDER=deepseek and provide a key to use DeepSeek as the backend.
# Users can also provide their own DeepSeek key via the app settings.
DEEPSEEK_API_KEY=sk-...

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=codelm
POSTGRES_USER=codelm
POSTGRES_PASSWORD=codelm

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=codelm

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── Backend server ────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765

# ── Parser feature flags ──────────────────────────────────────────────────────
# Enable tree-sitter for Java parsing. Default: false (regex only).
# When enabling, run a full scan to rebuild the graph with improved accuracy.
USE_TREE_SITTER_JAVA=false

# ── Hypothesis engine (experimental) ──────────────────────────────────────────
# Enable hypothesis-driven exploration. Default: false (legacy agent-based).
HYPOTHESIS_MODE_ENABLED=false
