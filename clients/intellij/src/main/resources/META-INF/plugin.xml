<idea-plugin>
    <id>ai.engram.plugin</id>
    <name>CodeLM</name>
    <vendor email="support@codelm.ai" url="https://codelm.ai">CodeLM</vendor>
    <description>
        AI Software Architect — persistent project memory, code graph analysis,
        architecture enforcement, and intelligent code generation.
    </description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="CodeLM"
            anchor="right"
            factoryClass="ai.engram.plugin.toolwindow.EngramToolWindowFactory"
            icon="/icons/engram.svg"
        />
        <applicationService
            serviceImplementation="ai.engram.plugin.client.BackendClient"
        />
        <projectService
            serviceImplementation="ai.engram.plugin.client.ProjectSession"
        />
    </extensions>

    <actions>
        <action
            id="CodeLM.ScanProject"
            class="ai.engram.plugin.actions.ScanProjectAction"
            text="Scan Project with CodeLM"
            description="Index current project into CodeLM knowledge base"
        >
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
